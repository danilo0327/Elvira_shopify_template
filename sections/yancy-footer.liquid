<footer class="yancy-footer">
  <div class="yancy-footer-grid">
    <div>
      <div class="yancy-logo" style="display:inline-block;margin-bottom:1rem;">{{ section.settings.logo_text | default: 'YANCY' }}</div>
      <p>{{ section.settings.tagline | default: 'Colombian handmade textile studio.' }}</p>
      {%- if section.settings.show_social -%}
        {%- render 'social-icons', class: 'yancy-footer-social' -%}
      {%- endif -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <strong>{{ block.settings.heading }}</strong>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</footer>

{% schema %}
{
  "name": "Yancy: Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "YANCY"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Colombian handmade textile studio."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Choose an existing navigation menu from your store"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Yancy: Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Shop" } },
        { "type": "link_list", "settings": { "heading": "Company" } }
      ]
    }
  ]
}
{% endschema %}
