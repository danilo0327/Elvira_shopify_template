{%- liquid
  assign bg_image = section.settings.image
  if bg_image != blank
    assign bg_url = bg_image | image_url: width: 2200
  else
    assign bg_url = 'https://images.unsplash.com/photo-1523398002811-999ca8dec234?auto=format&fit=crop&w=2200&q=80'
  endif
-%}

<section
  class="yancy-hero"
  style="background-image: linear-gradient(rgba(0,0,0,.18), rgba(0,0,0,.18)), url('{{ bg_url }}');"
>
  <div class="yancy-hero-content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="yancy-eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1>{{ section.settings.heading }}</h1>
    {%- if section.settings.text != blank -%}
      <p>{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a class="yancy-btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Yancy: Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Discover the new silhouette"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handmade Textile Studio"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Bolsos, accesorios y piezas para el hogar creadas por artesanos colombianos."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Yancy: Hero"
    }
  ]
}
{% endschema %}
