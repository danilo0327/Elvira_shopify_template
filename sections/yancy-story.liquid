<section id="story" class="yancy-story">
  <div class="yancy-story-inner">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1400 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width | default: 1400 }}"
        height="{{ section.settings.image.height | default: 1750 }}"
      >
    {%- else -%}
      <img
        src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&w=1400&q=80"
        alt="Artisan process"
        loading="lazy"
        width="1400"
        height="1750"
      >
    {%- endif -%}
    <div class="yancy-story-copy">
      {%- if section.settings.eyebrow != blank -%}
        <div class="yancy-eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="yancy-grid-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a class="yancy-btn" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Yancy: Story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Our story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A slow fashion experience."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Cuenta la historia de la marca, los materiales, las manos artesanas y el proceso detrás de cada pieza. Este bloque funciona muy bien para transmitir valor antes de llevar al usuario al producto."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Discover more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Yancy: Story"
    }
  ]
}
{% endschema %}
